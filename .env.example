# ──────────────────────────────────────────────────────────────
# Seevak Care — Environment Variables
# Copy this file to .env.local and fill in your values.
# ──────────────────────────────────────────────────────────────

# ── Database (Neon / Postgres) ────────────────────────────────
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/seevakcare?sslmode=require"
# For migrations use the direct (non-pooled) URL:
DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/seevakcare?sslmode=require"

# ── App ───────────────────────────────────────────────────────
NEXTAUTH_SECRET="change-me-to-a-random-32-char-string"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Seevak Care"

# ── SMTP (Gmail with App Password) ───────────────────────────
# Generate App Password: Google Account → Security → 2-Step Verification → App Passwords
SMTP_USER="seevakcare@gmail.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"   # your 16-char Gmail App Password
SMTP_FROM="seevakcare@gmail.com"
SUPPORT_EMAIL="seevakcare@gmail.com"
SUPPORT_PHONE="+919771365160"

# ── Razorpay ─────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxx"

# ── Optional: Twilio WhatsApp ─────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
